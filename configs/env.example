# Copy to .env (gitignored) and fill in. Inject these into the process
# environment in production via your secret manager — do not commit real values.

# Required: OAuth 2.0 client credentials from the Toss developer console.
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# Optional: defaults to https://openapi.tossinvest.com
# Must be https — plain http is rejected at boot (credentials would travel
# unencrypted), except for loopback hosts (localhost/127.0.0.1) used by tests.
TOSS_BASE_URL=

# REQUIRED for cmd/bot: accountSeq for X-Tossinvest-Account (from
# GET /api/v1/accounts). Must be numeric. cmd/bot refuses to assemble without it
# — every account-scoped call (order submit, order lookup, reconciliation) would
# otherwise target no account at all. config.Load itself tolerates it being
# absent, because other callers may not need it; the bot's assembly is what
# requires it.
TOSS_ACCOUNT_SEQ=

# --- cmd/bot durable state ---
# Both are created if absent. Put them on persistent storage: the order journal
# and the clean-shutdown sentinel are what make a restart safe, so losing them
# makes every boot look like a first boot (which comes up halted by design).

# Optional: defaults to data/bot.db
# The path must not contain '#', '?' or '%' — those corrupt the SQLite URI DSN
# and are rejected at open, because the engine could otherwise silently open a
# DIFFERENT file than the journal a restart must reopen.
TOSS_BOT_STORE_PATH=

# Optional: defaults to data/audit
TOSS_BOT_AUDIT_DIR=

# --- cmd/bot escalation thresholds ---
# All optional; defaults shown. Each must be > 0 if set — a zero would mean
# "never escalates", silently disarming the kill switch, so the process refuses
# to start rather than trade unguarded.

# Consecutive order failures that trip the global halt.
# TOSS_BOT_ORDER_FAILURE_THRESHOLD=3

# Token-refresh failures within the window that trip the global halt.
# TOSS_BOT_TOKEN_REFRESH_THRESHOLD=3
# TOSS_BOT_TOKEN_REFRESH_WINDOW=15m

# Unresolved-ambiguous intent backlog that trips the global halt.
# TOSS_BOT_AMBIGUOUS_BACKLOG_THRESHOLD=3

# How long a submitted-but-unacknowledged order may stay in flight before it is
# declared ambiguous.
# TOSS_BOT_SETTLE_WINDOW=30s

# Reconciler re-evaluation cadence: bounds the escalation windows in a quiet
# market where nothing is being submitted and no wake ever fires.
# TOSS_BOT_REEVAL_INTERVAL=1m

# How long shutdown waits for supervised loops to drain. A drain timeout is
# treated as an unclean exit, so the next boot comes up conservatively halted.
# TOSS_BOT_SHUTDOWN_TIMEOUT=10s

# --- cmd/presence-check (ADR-0009 point 8) ---
# Not used by cmd/bot; only by the presence-check CLI.

# Required: "owner/repo" to check branch protection/CODEOWNERS against.
GITHUB_REPOSITORY=

# Optional: admin-capable token to read branch protection (check (b)). The
# GitHub App deliberately lacks Administration permission (ADR-0009 point 6),
# so this must be a separate credential from the App. Falls back to
# GITHUB_TOKEN if unset.
GITHUB_ADMIN_TOKEN=

# Withdrawn (ADR-0011 point 10): App credentials are no longer read for
# identity resolution (check (c)) — key possession is not authorship evidence
# (semantic false positive). Check (c) is hard fail-closed until the ADR-0011
# c-1/c-2 redefinition lands; these stay documented only so operators know
# setting them has no effect on presence-check.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_PRIVATE_KEY=

# Optional: fallback for GITHUB_ADMIN_TOKEN (check (b)).
GITHUB_TOKEN=

# Optional overrides (defaults shown):
# PRESENCE_CHECK_BRANCH=main
# PRESENCE_CHECK_CODEOWNERS_PATH=.github/CODEOWNERS  # path *on GITHUB_REPOSITORY@PRESENCE_CHECK_BRANCH*,
#                                                      # fetched via the Contents API — never read from local disk,
#                                                      # so a feature branch or dirty checkout can't spoof it.
# PRESENCE_CHECK_EXPECTED_ACTOR=mechanu[bot]
